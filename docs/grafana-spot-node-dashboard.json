    {
      "id": 16,
      "title": "CPU: Total Reserved vs Used",
      "description": "Node-level CPU overview: allocatable capacity vs total requested vs total actual usage. Gray = headroom, yellow = reserved, green = used.",
      "type": "timeseries",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 65
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "scalar(kube_node_status_allocatable{resource=\"cpu\", node=~\"$node\"})",
          "legendFormat": "Allocatable",
          "range": true
        },
        {
          "refId": "B",
          "expr": "sum(kube_pod_container_resource_requests{resource=\"cpu\", node=~\"$node\"})",
          "legendFormat": "Total Requested",
          "range": true
        },
        {
